datasource db {
  provider = "mysql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

enum OtpType {
  email
  mobile
}

enum LessonType {
  video
  document
  quiz
}

enum QuestionType {
  MCQ
  FILLINTHEBLANK
  TRUEORFALSE
  SHORTANSWER
  DECRIPTIVE
}

enum Difficulty {
  easy
  medium
  hard
}

enum BloomLevel {
  remember
  understand
  apply
  analyze
  evaluate
  create
}

enum SubmissionType {
  pdf
  video
  image
  link
  text
}

enum GradingMethod {
  manual
  rubric
}

enum SubmissionStatus {
  not_submitted
  submitted
  late_submitted
  under_review
  graded
  re_submitted
}

enum LetterGrade {
  A_PLUS
  A
  B
  B_PLUS
  C_PLUS
  C
  D
  F
}

enum CertificateType {
  project_completion
  course_completion
  achievement
}

enum CertificateBrand {
  edudigm
  stempowered
}

enum InstitutionMemberRole {
  ADMIN
  TEACHER
  STUDENT
}

enum EnrollmentSource {
  INDIVIDUAL
  INSTITUTION
}

model User {
  id                  Int                  @id @default(autoincrement())
  uuid                String               @unique @default(uuid())
  email               String               @unique
  name                String?
  username            String?              @unique
  dateOfBirth         DateTime?
  avatar              String?
  classGrade          String?
  mobile_prefix       String               @default("+91")
  mobile              String?
  about               String?              @db.Text
  password            String
  status              Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  certificates        Certificate[]
  roles               Role[]               @relation("userroles")
  teacherCourses      CourseTeacher[]      @relation("TeacherCourses")
  quizAttempts        QuizAttempt[]
  skills              UserSkill[]          @relation("UserSkill")
  projects            UserProject[]        @relation("userProjects")
  forums              CourForum[]          @relation("userForum")
  forumReactions      ForumReaction[]      @relation("UserForumReactions")
  payments            Payment[]            @relation("UserPayments")
  userEnrolledCourses UserEnrolledCourse[] @relation("UserEnrolledCourses")
  xpEarned            UserXPEarned[]
  teacherProjects     Project[]            @relation("TeacherProjects")
  studentSubmissions  ProjectSubmission[]  @relation("StudentSubmissions")
  gradesGiven         ProjectGrade[]       @relation("TeacherGrades")
  ownedInstitutions   Institution[]        @relation("InstitutionOwner")
  institutionMembers  InstitutionMember[]  @relation("InstitutionMemberships")

  @@map("users")
}

model Role {
  id          Int          @id @default(autoincrement())
  name        String       @unique
  description String
  slug        String       @unique
  status      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  permissions Permission[] @relation("rolepermissions")
  users       User[]       @relation("userroles")

  @@map("roles")
}

model Permission {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  roles       Role[]   @relation("rolepermissions")

  @@map("permissions")
}

model UserOtp {
  id             Int      @id @default(autoincrement())
  type           OtpType  @default(mobile)
  email          String?  @unique
  mobilePrefix   String?
  mobile         String?  @unique
  code           String   @db.VarChar(20)
  resend         Int      @default(0)
  failedAttempts Int      @default(0)
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("user_otps")
}

model Course {
  id                  Int                  @id @default(autoincrement())
  title               String
  slug                String               @unique
  thumbnail           String
  grade               String
  duration            String
  price               Decimal              @db.Decimal(10, 2)
  discountedPrice     Decimal              @db.Decimal(10, 2)
  description         String               @db.Text
  status              Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  teachers            CourseTeacher[]      @relation("CourseTeachers")
  subjects            CourseSubject[]      @relation("CourseSubjects")
  forums              CourForum[]          @relation("courseForum")
  payments            Payment[]            @relation("CoursePayments")
  userEnrolledCourses UserEnrolledCourse[] @relation("CourseEnrolledUsers")
  courseQuizzes       CourseQuiz[]
  projects            Project[]            @relation("CourseProjects")
  gradeScale          GradeScale?          @relation("CourseGradeScale")
  institutionCourses  InstitutionCourse[]  @relation("InstitutionCourses")

  @@map("courses")
}

model CourseTeacher {
  id        Int      @id @default(autoincrement())
  courseId  Int
  teacherId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation("CourseTeachers", fields: [courseId], references: [id], onDelete: Cascade)
  teacher   User     @relation("TeacherCourses", fields: [teacherId], references: [id])

  @@map("course_teachers")
}

model Subject {
  id          Int              @id @default(autoincrement())
  name        String
  slug        String           @unique
  description String           @db.Text
  status      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  courses     CourseSubject[]  @relation("SubjectCourses")
  chapters    SubjectChapter[] @relation("SubjectChapters")

  modules        Module[]
  subjectQuizzes SubjectQuiz[]
  forum          CourForum[]   @relation("ForumToSubject")

  @@map("subjects")
}

model CourseSubject {
  id        Int      @id @default(autoincrement())
  courseId  Int
  subjectId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  course    Course   @relation("CourseSubjects", fields: [courseId], references: [id], onDelete: Cascade)
  subject   Subject  @relation("SubjectCourses", fields: [subjectId], references: [id])

  @@map("course_subjects")
}

model Chapter {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  status      Boolean  @default(true)
  description String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subjects       SubjectChapter[]  @relation("SubjectChapters")
  modules        ModuleChapter[]
  lessons        LessonToChapter[] @relation("LessonToChapters")
  chapterQuizzes ChapterQuiz[]
  forum          CourForum[]       @relation("ForumToChapter")

  @@map("chapters")
}

model SubjectChapter {
  id        Int      @id @default(autoincrement())
  subjectId Int
  chapterId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  subject   Subject  @relation("SubjectChapters", fields: [subjectId], references: [id])
  chapter   Chapter  @relation("SubjectChapters", fields: [chapterId], references: [id])

  @@map("subject_chapters")
}

model Module {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  description String?  @db.Text
  status      Boolean  @default(true)
  subjectId   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // ✅ OPPOSITE FIELD EXISTS IN Subject
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  // ✅ OPPOSITE FIELD EXISTS IN Chapter
  chapters      ModuleChapter[]
  moduleQuizzes ModuleQuiz[]

  @@map("modules")
}

model ModuleChapter {
  id        Int      @id @default(autoincrement())
  moduleId  Int
  chapterId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ✅ Relation names consistent
  module  Module  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([moduleId, chapterId])
  @@map("module_chapters")
}

model Lesson {
  id           Int               @id @default(autoincrement())
  title        String
  slug         String            @unique
  description  String            @db.Text
  status       Boolean           @default(true)
  topicName    String
  duration     String?
  videoUrl     String?
  NoOfPages    Int?
  noOfXpPoints Int               @default(0)
  type         LessonType        @default(video)
  docUrl       String?
  sortOrder    Int?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  chapters     LessonToChapter[] @relation("LessonToChapters")
  quizzes      LessonQuiz[]
  xpEarned     UserXPEarned[]
  forum        CourForum[]       @relation("ForumToLesson")

  @@map("lessons")
}

model LessonToChapter {
  id        Int      @id @default(autoincrement())
  lessonId  Int
  chapterId Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lesson    Lesson   @relation("LessonToChapters", fields: [lessonId], references: [id])
  chapter   Chapter  @relation("LessonToChapters", fields: [chapterId], references: [id])

  @@map("lesson_to_chapter")
}

model Quiz {
  id         Int      @id @default(autoincrement())
  title      String
  slug       String   @unique
  totalMarks Int      @default(0)
  passMarks  Int      @default(0)
  timeLimit  Decimal  @db.Decimal(10, 2)
  status     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  questions Question[]

  lessons LessonQuiz[]

  courseQuizzes  CourseQuiz[]
  subjectQuizzes SubjectQuiz[]
  moduleQuizzes  ModuleQuiz[]
  chapterQuizzes ChapterQuiz[]
  quizAttempts   QuizAttempt[]
  userXPEarneds  UserXPEarned[]

  @@map("quizzes")
}

model LessonQuiz {
  id        Int      @id @default(autoincrement())
  lessonId  Int
  quizId    Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([lessonId, quizId])
  @@map("lesson_quizzes")
}

model QuizAttempt {
  id     Int @id @default(autoincrement())
  quizId Int
  userId Int

  obtainedMarks  Decimal  @db.Decimal(10, 2)
  totalMarks     Decimal  @db.Decimal(10, 2)
  correctAnswers Int
  totalQuestions Int
  timeTaken      Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  answers QuestionAttempt[] @relation("AttemptAnswers")

  @@map("quiz_attempts")
}

model QuestionAttempt {
  id            Int @id @default(autoincrement())
  quizAttemptId Int
  questionId    Int

  obtainedMarks Decimal @db.Decimal(10, 2) // e.g. 1.0, 4.0
  totalMarks    Decimal @db.Decimal(10, 2) // e.g. 1.0, 5.0
  timeTaken     Int? // time taken in seconds
  isCorrect     Boolean

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quizAttempt QuizAttempt @relation("AttemptAnswers", fields: [quizAttemptId], references: [id])
  question    Question    @relation(fields: [questionId], references: [id])

  @@unique([quizAttemptId, questionId])
  @@map("question_attempts")
}

model Question {
  id         Int          @id @default(autoincrement())
  quizId     Int
  question   String       @db.Text
  status     Boolean      @default(true)
  marks      Int
  duration   Decimal      @default(0) @db.Decimal(10, 2)
  type       QuestionType @default(MCQ)
  difficulty Difficulty   @default(medium)
  bloomLevel BloomLevel   @default(remember)
  answer     String?      @db.Text
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  quiz             Quiz              @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionAttempts QuestionAttempt[]
  options          QuestionOption[]  @relation("QuestionOptions")

  @@map("questions")
}

model QuestionOption {
  id         Int      @id @default(autoincrement())
  questionId Int
  option     String   @db.Text
  status     Boolean  @default(true)
  isCorrect  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  question   Question @relation("QuestionOptions", fields: [questionId], references: [id])

  @@map("question_options")
}

model UserSkill {
  id        Int      @id @default(autoincrement())
  userId    Int
  skill     String
  level     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation("UserSkill", fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_skills")
}

model UserProject {
  id          Int       @id @default(autoincrement())
  userId      Int
  title       String
  description String    @db.Text
  status      Boolean   @default(true)
  imageUrl    String?
  date        DateTime?
  demoUrl     String?
  gitHubUrl   String?
  user        User      @relation("userProjects", fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("user_projects")
}

model CourForum {
  id          Int               @id @default(autoincrement())
  courseId    Int
  userId      Int
  title       String?
  content     String            @db.Text
  parentId    Int?
  lessonId    Int?
  chapterId   Int?
  subjectId   Int?
  status      Boolean           @default(true)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  //add self relation for parent forum post
  parent      CourForum?        @relation("ForumReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     CourForum[]       @relation("ForumReplies")
  course      Course            @relation("courseForum", fields: [courseId], references: [id], onDelete: Cascade)
  user        User              @relation("userForum", fields: [userId], references: [id], onDelete: Cascade)
  reaction    ForumReaction[]   @relation("ForumReactions")
  lesson      Lesson?           @relation("ForumToLesson", fields: [lessonId], references: [id], onDelete: Cascade)
  chapter     Chapter?          @relation("ForumToChapter", fields: [chapterId], references: [id], onDelete: Cascade)
  subject     Subject?          @relation("ForumToSubject", fields: [subjectId], references: [id], onDelete: Cascade)
  attachments ForumAttachment[] @relation("ForumAttachments")

  @@map("course_forum")
}

model ForumAttachment {
  id        Int       @id @default(autoincrement())
  forumId   Int
  fileUrl   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  forum     CourForum @relation("ForumAttachments", fields: [forumId], references: [id], onDelete: Cascade)

  @@map("forum_attachments")
}

model ForumReaction {
  id        Int       @id @default(autoincrement())
  forumId   Int
  userId    Int
  emoji     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  forum     CourForum @relation("ForumReactions", fields: [forumId], references: [id], onDelete: Cascade)
  user      User      @relation("UserForumReactions", fields: [userId], references: [id], onDelete: Cascade)

  @@map("forum_reactions")
}

model Payment {
  id                 Int                 @id @default(autoincrement())
  userId             Int
  amount             Decimal             @db.Decimal(10, 2)
  currency           String
  status             String              @default("pending")
  paymentDate        DateTime            @default(now())
  paymentVerifiedAt  DateTime?
  razorPayOrderId    String?
  razorPayPaymentId  String?
  courseId           Int
  paymentReference   String?
  paymentMetaData    Json?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  user               User                @relation("UserPayments", fields: [userId], references: [id], onDelete: Cascade)
  course             Course              @relation("CoursePayments", fields: [courseId], references: [id], onDelete: Cascade)
  userEnrolledCourse UserEnrolledCourse? @relation("UserEnrolledCoursePayment")

  @@map("payments")
}

model UserEnrolledCourse {
  id            Int              @id @default(autoincrement())
  userId        Int
  courseId      Int
  paymentId     Int?             @unique // nullable — institution enrollments skip payment
  sourceType    EnrollmentSource @default(INDIVIDUAL)
  institutionId Int? // set when sourceType = INSTITUTION
  enrolledAt    DateTime         @default(now())
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  user        User         @relation("UserEnrolledCourses", fields: [userId], references: [id], onDelete: Cascade)
  course      Course       @relation("CourseEnrolledUsers", fields: [courseId], references: [id], onDelete: Cascade)
  payment     Payment?     @relation("UserEnrolledCoursePayment", fields: [paymentId], references: [id], onDelete: Cascade)
  institution Institution? @relation("InstitutionEnrollments", fields: [institutionId], references: [id], onDelete: SetNull)

  @@unique([userId, courseId, sourceType]) // same student can enrol via both sources
  @@map("user_enrolled_courses")
}

model UserXPEarned {
  id        Int      @id @default(autoincrement())
  userId    Int
  xpPoints  Int      @default(0)
  lessonId  Int?
  quizId    Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson? @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  quiz   Quiz?   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@map("user_xp_earneds")
}

model CourseQuiz {
  id        Int      @id @default(autoincrement())
  courseId  Int
  quizId    Int
  createdAt DateTime @default(now())

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([courseId, quizId])
  @@map("course_quizzes")
}

model SubjectQuiz {
  id        Int      @id @default(autoincrement())
  subjectId Int
  quizId    Int
  createdAt DateTime @default(now())

  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  quiz    Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([subjectId, quizId])
  @@map("subject_quizzes")
}

model ModuleQuiz {
  id        Int      @id @default(autoincrement())
  moduleId  Int
  quizId    Int
  createdAt DateTime @default(now())

  module Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  quiz   Quiz   @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([moduleId, quizId])
  @@map("module_quizzes")
}

model ChapterQuiz {
  id        Int      @id @default(autoincrement())
  chapterId Int
  quizId    Int
  createdAt DateTime @default(now())

  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  quiz    Quiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([chapterId, quizId])
  @@map("chapter_quizzes")
}

model Project {
  id             Int            @id @default(autoincrement())
  courseId       Int
  createdBy      Int
  title          String
  slug           String         @unique
  description    String         @db.Text
  submissionType SubmissionType @default(pdf)
  deadline       DateTime
  maxMarks       Int
  gradingMethod  GradingMethod  @default(manual)
  /// Weight of this project in the course final score (0–100)
  weightPercent  Decimal        @default(0) @db.Decimal(5, 2)
  allowLate      Boolean        @default(false)
  /// Max file size per upload in MB
  maxFileSizeMb  Int            @default(50)
  status         Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  course      Course              @relation("CourseProjects", fields: [courseId], references: [id], onDelete: Cascade)
  creator     User                @relation("TeacherProjects", fields: [createdBy], references: [id])
  rubrics     ProjectRubric[]     @relation("ProjectRubrics")
  submissions ProjectSubmission[] @relation("ProjectSubmissions")

  @@map("projects")
}

/// Rubric criteria for a project (only used when gradingMethod = rubric)
model ProjectRubric {
  id          Int     @id @default(autoincrement())
  projectId   Int
  title       String
  description String? @db.Text
  /// Weight % of this criterion — all rubrics for a project must sum to 100
  weight      Decimal @db.Decimal(5, 2)
  maxMarks    Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project       @relation("ProjectRubrics", fields: [projectId], references: [id], onDelete: Cascade)
  grades  RubricGrade[] @relation("RubricGrades")

  @@map("project_rubrics")
}

/// A student's submission for a project (one per student per project)
model ProjectSubmission {
  id          Int              @id @default(autoincrement())
  projectId   Int
  studentId   Int
  status      SubmissionStatus @default(not_submitted)
  description String?          @db.Text
  /// Increments on every re-submission
  version     Int              @default(1)
  submittedAt DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  project Project             @relation("ProjectSubmissions", fields: [projectId], references: [id], onDelete: Cascade)
  student User                @relation("StudentSubmissions", fields: [studentId], references: [id], onDelete: Cascade)
  files   SubmissionFile[]    @relation("SubmissionFiles")
  grade   ProjectGrade?       @relation("SubmissionGrade")
  history SubmissionHistory[] @relation("SubmissionHistory")

  /// One submission record per student per project
  @@unique([projectId, studentId])
  @@map("project_submissions")
}

/// Files or external links attached to a submission
model SubmissionFile {
  id           Int            @id @default(autoincrement())
  submissionId Int
  fileType     SubmissionType
  fileUrl      String
  originalName String?
  fileSizeKb   Int?
  /// Which submission version this file was uploaded in
  version      Int            @default(1)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  submission ProjectSubmission @relation("SubmissionFiles", fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("submission_files")
}

/// Snapshot of a submission saved before each re-submission
model SubmissionHistory {
  id            Int              @id @default(autoincrement())
  submissionId  Int
  version       Int
  status        SubmissionStatus
  description   String?          @db.Text
  snapshottedAt DateTime         @default(now())

  submission ProjectSubmission @relation("SubmissionHistory", fields: [submissionId], references: [id], onDelete: Cascade)

  @@map("submission_history")
}

/// Grade record for a submission — supports both manual and rubric grading
model ProjectGrade {
  id            Int          @id @default(autoincrement())
  submissionId  Int          @unique
  teacherId     Int
  obtainedMarks Decimal      @db.Decimal(10, 2)
  totalMarks    Decimal      @db.Decimal(10, 2)
  percentage    Decimal      @db.Decimal(5, 2)
  letterGrade   LetterGrade?
  feedback      String?      @db.Text
  /// When false the student cannot see this grade yet
  isPublished   Boolean      @default(false)
  gradedAt      DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  submission   ProjectSubmission @relation("SubmissionGrade", fields: [submissionId], references: [id], onDelete: Cascade)
  teacher      User              @relation("TeacherGrades", fields: [teacherId], references: [id])
  rubricGrades RubricGrade[]     @relation("GradeRubrics")

  @@map("project_grades")
}

/// Per-criterion marks when rubric grading is used
model RubricGrade {
  id        Int      @id @default(autoincrement())
  gradeId   Int
  rubricId  Int
  marks     Decimal  @db.Decimal(10, 2)
  comment   String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  grade  ProjectGrade  @relation("GradeRubrics", fields: [gradeId], references: [id], onDelete: Cascade)
  rubric ProjectRubric @relation("RubricGrades", fields: [rubricId], references: [id], onDelete: Cascade)

  @@unique([gradeId, rubricId])
  @@map("rubric_grades")
}

/// Custom percentage → letter grade mapping for a course (optional)
model GradeScale {
  id        Int      @id @default(autoincrement())
  courseId  Int      @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course Course           @relation("CourseGradeScale", fields: [courseId], references: [id], onDelete: Cascade)
  bands  GradeScaleBand[] @relation("ScaleBands")

  @@map("grade_scales")
}

/// Each percentage band in a grade scale
model GradeScaleBand {
  id          Int         @id @default(autoincrement())
  scaleId     Int
  minPercent  Decimal     @db.Decimal(5, 2)
  maxPercent  Decimal     @db.Decimal(5, 2)
  letterGrade LetterGrade
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  scale GradeScale @relation("ScaleBands", fields: [scaleId], references: [id], onDelete: Cascade)

  @@map("grade_scale_bands")
}

model Certificate {
  id                Int              @id @default(autoincrement())
  certificateNumber String           @unique
  userId            Int
  submissionId      Int?             @unique
  type              CertificateType
  title             String
  studentName       String
  className         String
  projectTitle      String?
  courseName        String
  grade             String?
  teacherRemarks    String?          @db.Text
  completionDate    DateTime
  brandLogo         CertificateBrand

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("certificates")
}

model Institution {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid())
  name      String
  slug      String   @unique
  logo      String?
  address   String?  @db.Text
  website   String?
  ownerId   Int
  status    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner              User                 @relation("InstitutionOwner", fields: [ownerId], references: [id])
  members            InstitutionMember[]  @relation("InstitutionMembers")
  institutionCourses InstitutionCourse[]  @relation("InstitutionCourses")
  enrollments        UserEnrolledCourse[] @relation("InstitutionEnrollments")

  @@map("institutions")
}

model InstitutionMember {
  id            Int                   @id @default(autoincrement())
  institutionId Int
  userId        Int
  status        Boolean               @default(true)
  joinedAt      DateTime              @default(now())
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  institution Institution @relation("InstitutionMembers", fields: [institutionId], references: [id], onDelete: Cascade)
  user        User        @relation("InstitutionMemberships", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([institutionId, userId])
  @@map("institution_members")
}

model InstitutionCourse {
  id            Int      @id @default(autoincrement())
  institutionId Int
  courseId      Int
  purchasedAt   DateTime @default(now())
  seats         Int? // null = unlimited
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  institution Institution @relation("InstitutionCourses", fields: [institutionId], references: [id], onDelete: Cascade)
  course      Course      @relation("InstitutionCourses", fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([institutionId, courseId])
  @@map("institution_courses")
}
